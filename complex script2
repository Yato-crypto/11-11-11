            if State.allyMarkers[characterModel].connection then
                State.allyMarkers[characterModel].connection:Disconnect()
            end
        end)
        State.allyMarkers[characterModel] = nil
    end
    
    -- Store ally status by model name for persistence across respawns
    local modelName = characterModel.Name
    State.alliedModels[modelName] = true
    State.alliedModelReferences[characterModel] = modelName
    
