-- ============================================================
-- DODGE SYSTEM - Projectile Tracking
-- ============================================================
local function getObjectFolder(obj)
    for _, folderName in ipairs(MONITOR_FOLDERS) do
        local folder = Workspace:FindFirstChild(folderName)
        if folder and obj:IsDescendantOf(folder) then
            return folderName, folder
        end
    end
    return nil, nil
end

local function isIncludedQ(obj)
    if State.includedQObjects[obj] ~= nil then
        return State.includedQObjects[obj].included, State.includedQObjects[obj].prediction,
               State.includedQObjects[obj].key, State.includedQObjects[obj].dodgeDistance
    end
    
    local folderName, folder = getObjectFolder(obj)
    if not folderName or not folder then return false, 0, nil, nil end
    
    local current = obj
    while current and current ~= folder and current:IsDescendantOf(folder) do
        for _, entry in ipairs(PROJECTILE_CONFIG) do
            if current.Name == entry.name then
                local key = entry.key or "Q"
                local dodgeDist = entry.dodgeDistance or Config.Dodge.DodgeDistance
                State.includedQObjects[obj] = {included = true, prediction = entry.prediction, key = key, dodgeDistance = dodgeDist}
                return true, entry.prediction, key, dodgeDist
            end
        end
        current = current.Parent
    end
    
    State.includedQObjects[obj] = {included = false, prediction = 0, key = nil, dodgeDistance = nil}
    return false, 0, nil, nil
end

local function pressKey(keyName)
    if not Config.Dodge.Enabled then return end
    keyName = keyName or "Q"
    if keyName == "" then return end
    
    local now = tick()
    if now - State.lastDodgeTime < Config.Dodge.DodgeCooldown then return end
    
    State.lastDodgeTime = now
    State.dodgeActive = true
    
    local keyCode = Enum.KeyCode[keyName]
    if not keyCode then
        warn("[DODGE] Invalid key: " .. tostring(keyName))
        keyCode = Enum.KeyCode.Q
    end
    
    debugPrint("dodge", "🛡️ DODGING - " .. keyName)
    
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        task.wait(0.02)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
    
    task.delay(0.3, function() State.dodgeActive = false end)
end

local function trackProjectile(obj)
    if State.trackedObjects[obj] then return end
    local initialPos = nil
    if obj:IsA("BasePart") then
        initialPos = obj.Position
    elseif obj:IsA("Model") then
        local primaryPart = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if primaryPart then initialPos = primaryPart.Position end
    end
    
    if not initialPos then return end
    
    local isIncluded, predictionTime, keyToPress, dodgeDist = isIncludedQ(obj)
    if not isIncluded then return end
    
    State.trackedObjects[obj] = {
        lastPos = initialPos,
        lastTime = tick(),
        velocity = Vector3.new(0, 0, 0),
        speed = 0,
        predictionTime = predictionTime or 0,
        dodgeKey = keyToPress or "Q",
        dodgeDistance = dodgeDist or Config.Dodge.DodgeDistance
    }
    
    obj.AncestryChanged:Connect(function()
        if not obj:IsDescendantOf(Workspace) then
            State.trackedObjects[obj] = nil
            State.includedQObjects[obj] = nil
        end
    end)
end

local function calculateVelocity(obj, currentPos, lastData)
    if not lastData or not lastData.lastPos or not lastData.lastTime then
        return Vector3.new(0, 0, 0), 0
    end
    local deltaTime = tick() - lastData.lastTime
    if deltaTime <= 0 then
        return lastData.velocity or Vector3.new(0, 0, 0), lastData.speed or 0
    end
    
    local deltaPos = currentPos - lastData.lastPos
    local velocity = deltaPos / deltaTime
    local speed = velocity.Magnitude
    
    return velocity, speed
end

local function getObjectSize(obj)
    if not Config.Dodge.UseSizeDetection then
        return 2
    end
    local size = 2
    if obj:IsA("BasePart") then
        size = math.max(obj.Size.X, obj.Size.Y, obj.Size.Z)
    elseif obj:IsA("Model") then
        local _, objSize = obj:GetBoundingBox()
        size = math.max(objSize.X, objSize.Y, objSize.Z)
    end
    
    return size * Config.Dodge.SizeMultiplier
end

local function shouldTestOwnership(obj)
    if not Config.Dodge.UseOwnershipWhitelist then
        return true
    end
    local folderName, folder = getObjectFolder(obj)
    if not folderName or not folder then return false end
    
    local current = obj
    while current and current ~= folder and current:IsDescendantOf(folder) do
        for _, whitelistedName in ipairs(OWNERSHIP_WHITELIST) do
            if current.Name == whitelistedName then
                return true
            end
        end
        current = current.Parent
    end
    
    return false
end

local function isFromPlayer(obj, spawnPos)
    local hrp = myHRP()
    if not hrp or not spawnPos then return false end
    if Config.Dodge.UseOwnershipWhitelist and not shouldTestOwnership(obj) then
        return false
    end
    
    local currentTime = tick()
    if currentTime - State.lastAttackAnimationPlay <= Config.Dodge.AttackAnimationWindow then
        debugPrint("dodge", "🎯 Object spawned after attack animation: " .. obj.Name)
        return true
    end
    
    return false
end

local function checkQThreat(obj, objData)
    local hrp = myHRP()
    if not hrp then return false end
    if objData.fromPlayer or State.playerOwnedObjects[obj] then
        return false
    end
    
    if objData.passedBy then
        return false
    end
    
    local currentPos = nil
    if obj:IsA("BasePart") then
        currentPos = obj.Position
    elseif obj:IsA("Model") then
        local primaryPart = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if primaryPart then
            currentPos = primaryPart.Position
        end
    end
    
    if not currentPos then return false end
    
    local velocity, speed = calculateVelocity(obj, currentPos, objData)
    
    objData.lastPos = currentPos
    objData.lastTime = tick()
    objData.velocity = velocity
    objData.speed = speed
    
    if not objData.originChecked and speed > Config.Dodge.MinVelocity then
        objData.originChecked = true
        
        if not Config.Dodge.UseOwnershipWhitelist or shouldTestOwnership(obj) then
            local toPlayer = (hrp.Position - currentPos).Unit
            local velocityDir = velocity.Unit
            local dotProduct = toPlayer:Dot(velocityDir)
            
            if dotProduct < -0.5 then
                local distFromPlayer = (currentPos - hrp.Position).Magnitude
                if distFromPlayer <= Config.Dodge.OriginCheckDistance * 1.5 then
                    debugPrint("dodge", "🚫 Object moving away from player initially: " .. obj.Name)
                    objData.fromPlayer = true
                    State.playerOwnedObjects[obj] = true
                    return false
                end
            end
        end
    end
    
    if speed < Config.Dodge.MinVelocity then
        return false
    end
    
    local playerPos = hrp.Position
    local toPlayer = (playerPos - currentPos).Unit
    local velocityDir = velocity.Unit
    local dotProduct = toPlayer:Dot(velocityDir)
    local angle = math.deg(math.acos(math.clamp(dotProduct, -1, 1)))
    
    if angle > Config.Dodge.MaxAngleDeviation then
        return false
    end
    
    local toPlayerVec = playerPos - currentPos
    local t = toPlayerVec:Dot(velocity) / velocity:Dot(velocity)
    
    if t < 0 then
        return false
    end
    
    t = math.min(t, 2.0)
    local futureObjPos = currentPos + velocity * t
    local closestDist = (futureObjPos - playerPos).Magnitude
    
    local objSize = getObjectSize(obj)
    local baseDodgeDistance = objData.dodgeDistance or Config.Dodge.DodgeDistance
    local effectiveDodgeDistance = baseDodgeDistance + objSize
    
    local currentDistance = (currentPos - playerPos).Magnitude
    
    if currentDistance <= effectiveDodgeDistance * 2 then
        objData.hasBeenClose = true
    end
    
    if objData.hasBeenClose and speed >= Config.Dodge.MinVelocity then
        local toPlayer2 = (hrp.Position - currentPos).Unit
        local velocityDir2 = velocity.Unit
        local dotProduct2 = toPlayer2:Dot(velocityDir2)
        
        if dotProduct2 < -0.3 then
            objData.passedBy = true
            debugPrint("dodge", "✅ Projectile PASSED BY (dodged): " .. obj.Name)
            return false
        end
    end
    
    if closestDist <= effectiveDodgeDistance then
        local predictionWindow = (objData.predictionTime or 0) + Config.Dodge.DodgeAnticipation
        if t > 0 and t <= predictionWindow then
            debugPrint("dodge", string.format(
                "⚠️ THREAT DETECTED: %s | Dist: %.1f | Speed: %.1f | Time: %.2fs | Key: %s",
                obj.Name, closestDist, speed, t, objData.dodgeKey or "Q"
            ))
            return true, objData.dodgeKey
        end
    end
    
    return false, nil
end

