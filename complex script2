    if not Config.ESP.Enabled then return false end
    if isMyCharacter(characterModel) then return false end
    return true
end

local function getHealthColor(healthPercent)
    if healthPercent >= 75 then
        return Color3.fromRGB(100, 200, 255)
    elseif healthPercent >= 50 then
        return Color3.fromRGB(150, 220, 255)
    elseif healthPercent >= 25 then
        return Color3.fromRGB(255, 180, 150)
    else
        return Color3.fromRGB(255, 100, 100)
    end
end

