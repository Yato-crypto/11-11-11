            end
        else
            abilityFrame.Visible = false
        end
    end
    
    local statusSection = mainFrame:FindFirstChild("StatusSection")
    if statusSection then
        local aimRow = statusSection:FindFirstChild("AimLockRow")
        if aimRow then
            local indicator = aimRow:FindFirstChild("Indicator")
