-- Execute a single macro action (key press or mouse click)
local function executeMacroAction(action)
    if not Config.Macros.Enabled then return end
    
    -- Handle keyboard key presses
    if action.key then
        debugPrint("macro", "Pressing key: " .. tostring(action.key))
        pcall(function()
            VirtualInputManager:SendKeyEvent(true, action.key, false, game)
            task.wait(action.holdTime or 0.05)
            VirtualInputManager:SendKeyEvent(false, action.key, false, game)
        end)
    
    -- Handle mouse button clicks
    elseif action.mouseButton ~= nil then
        local buttonName = action.mouseButton == 0 and "Left Click" or "Right Click"
        debugPrint("macro", "Clicking: " .. buttonName)
        pcall(function()
            VirtualInputManager:SendMouseButtonEvent(0, 0, action.mouseButton, true, game, 0)
            task.wait(action.holdTime or 0.05)
            VirtualInputManager:SendMouseButtonEvent(0, 0, action.mouseButton, false, game, 0)
        end)
    end
    
    -- Wait for the specified delay after the action
    if action.delayAfter and action.delayAfter > 0 then
        task.wait(action.delayAfter)
    end
end

-- Enhanced macro execution with dynamic key detection (for ability slot overriding)
local function executeMacroByName(macroName, detectedKey)
    if not Config.Macros.Enabled then return end
    if State.macroRunning then
        debugPrint("macro", "⚠️ Macro already running, ignoring: " .. macroName)
        return
    end
    
    local macroData = MACRO_LIBRARY[macroName]
    if not macroData then
        warn("[MACRO] Macro not found: " .. macroName)
        return
    end
    
    State.macroRunning = true
    debugPrint("macro", "🎮 Executing macro: " .. macroName .. (detectedKey and (" (using " .. tostring(detectedKey) .. ")") or ""))
    
    State.currentMacroThread = task.spawn(function()
        for i, action in ipairs(macroData.sequence) do
            if not State.macroRunning then break end
            
            -- If this is an ability macro and we have a detected key, override it
            if detectedKey and action.key and (action.key == Enum.KeyCode.Two or action.key == Enum.KeyCode.Three) then
                local overriddenAction = {
                    key = detectedKey,
                    holdTime = action.holdTime,
                    delayAfter = action.delayAfter
                }
                executeMacroAction(overriddenAction)
            else
                executeMacroAction(action)
            end
        end
        
        State.macroRunning = false
        State.currentMacroThread = nil
        debugPrint("macro", "✅ Macro completed: " .. macroName)
    end)
end

-- Execute a macro from the MACRO_CONFIG table (keybind-triggered)
local function executeMacro(macroConfig)
    if not Config.Macros.Enabled then return end
    if State.macroRunning then
        debugPrint("macro", "⚠️ Macro already running, ignoring trigger")
        return
    end
    
    local macroData = MACRO_LIBRARY[macroConfig.name]
    if not macroData then
        warn("[MACRO] Macro not found: " .. macroConfig.name)
        return
    end
    
    State.macroRunning = true
    debugPrint("macro", "🎮 Starting macro: " .. macroConfig.name .. " (" .. macroConfig.repeatCount .. " reps)")
    
    State.currentMacroThread = task.spawn(function()
        for repetition = 1, macroConfig.repeatCount do
            if not State.macroRunning then break end
            
            if macroConfig.repeatCount > 1 then
                debugPrint("macro", "📍 Repetition " .. repetition .. "/" .. macroConfig.repeatCount)
            end
            
            for i, action in ipairs(macroData.sequence) do
                if not State.macroRunning then break end
                executeMacroAction(action)
            end
        end
        
        State.macroRunning = false
        State.currentMacroThread = nil
        debugPrint("macro", "✅ Macro completed: " .. macroConfig.name)
    end)
end

