local function getHum(character)
    return character and character:FindFirstChildOfClass("Humanoid") or nil
end

local function getHRP(character)
    return character and character:FindFirstChild("HumanoidRootPart") or nil
end

local function myHRP()
    return getHRP(LP and LP.Character)
end

local function isAlive(characterModel)
    if not characterModel or not characterModel.Parent then return false end
    local hum = getHum(characterModel)
    return hum and hum.Health > 0
end

local function getPlayerFolder()
    return Workspace:FindFirstChild("Player")
end

local function isValidCharacterModel(model)
    if not model or not model:IsA("Model") then return false end
    if model == LP.Character then return false end
    
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    
    return true
end

local function refreshValidModels()
    local playerFolder = getPlayerFolder()
    if not playerFolder then
        State.validModels = {}
        return
    end
    
    local newValidModels = {}
    for _, child in ipairs(playerFolder:GetChildren()) do
        if isValidCharacterModel(child) then
            newValidModels[child] = true
        end
    end
    
    State.validModels = newValidModels
end

local function getAllTargetModels()
    refreshValidModels()
    
    local models = {}
    for model, _ in pairs(State.validModels) do
        if model and model.Parent then
            table.insert(models, model)
        end
    end
    return models
end

local function isMyCharacter(characterModel)
    return characterModel == LP.Character
end

local function debugPrint(system, msg)
    if system == "aim" and Config.AimLock.DebugMode then
        print("[AIM-LOCK]", msg)
    elseif system == "dodge" and Config.Dodge.DebugMode then
        print("[DODGE]", msg)
    elseif system == "triggerbot" and Config.Triggerbot.DebugPrints then
        print("[TRIGGERBOT]", msg)
    elseif system == "esp" then
        print("[ESP]", msg)
    elseif system == "macro" and Config.Macros.DebugMode then
        print("[MACRO]", msg)
    end
end

local function debounceInput(inputKey, cooldown)
    local now = tick()
    if State.inputBuffer[inputKey] and (now - State.inputBuffer[inputKey] < cooldown) then
        return false
    end
    State.inputBuffer[inputKey] = now
    return true
end

local function getBlockDelayForDistance(animData, distance)
    if animData.blockDistanceRanges then
        for _, range in ipairs(animData.blockDistanceRanges) do
            local maxDist = range[1]
            local delay = range[2]
            if distance <= maxDist then
                return delay
            end
        end
        return animData.blockDistanceRanges[#animData.blockDistanceRanges][2]
    end
    return 0
end

local CurveAnchors = {
    { d = 0,  f = 0.15 },
    { d = 10, f = 0.30 },
    { d = 20, f = 0.55 },
    { d = 30, f = 0.80 },
    { d = 40, f = 0.95 },
    { d = 60, f = 1.10 },
    { d = 80, f = 1.25 },
}

local function smoothstep(t) return t * t * (3 - 2 * t) end
local function lerp(a, b, t) return a + (b - a) * t end

local function curveFactor(distance)
    if distance <= CurveAnchors[1].d then return CurveAnchors[1].f end
    if distance >= CurveAnchors[#CurveAnchors].d then return CurveAnchors[#CurveAnchors].f end
    for i = 1, #CurveAnchors - 1 do
        local a, b = CurveAnchors[i], CurveAnchors[i + 1]
        if distance >= a.d and distance < b.d then
            local t = (distance - a.d) / math.max(1e-6, (b.d - a.d))
            return lerp(a.f, b.f, smoothstep(t))
        end
    end
    return 1.0
end

local function countBlacklisted()
