-- Update the unified HUD with current system states and performance metrics
local lastHUDUpdate = 0
local function updateUnifiedHUD()
    if not unifiedHUD then return end
    local now = tick()
    if now - lastHUDUpdate < 0.1 then return end
    lastHUDUpdate = now
    
    local mainFrame = unifiedHUD:FindFirstChild("MainFrame")
    if not mainFrame then return end
    
    if now - State.lastFPSUpdate >= 1 then
        State.currentFPS = State.frameCounter
        State.frameCounter = 0
        State.lastFPSUpdate = now
    end
    
    local fpsLabel = mainFrame:FindFirstChild("PerformanceSection"):FindFirstChild("FPSLabel")
    if fpsLabel then
        local fpsColor = State.currentFPS >= 60 and Color3.fromRGB(100, 255, 150) or
                        (State.currentFPS >= 30 and Color3.fromRGB(255, 200, 100) or Color3.fromRGB(255, 100, 100))
        fpsLabel.Text = string.format("FPS: %d", State.currentFPS)
        fpsLabel.TextColor3 = fpsColor
    end
    
    local ping = math.floor(LP:GetNetworkPing() * 1000)
    local pingLabel = mainFrame:FindFirstChild("PerformanceSection"):FindFirstChild("PingLabel")
    if pingLabel then
        local pingColor = ping < 100 and Color3.fromRGB(100, 255, 150) or
                         (ping < 200 and Color3.fromRGB(255, 200, 100) or Color3.fromRGB(255, 100, 100))
        pingLabel.Text = string.format("Ping: %d ms", ping)
        pingLabel.TextColor3 = pingColor
    end
    
    local abilityFrame = mainFrame:FindFirstChild("AbilityFrame")
    if abilityFrame then
        if State.activeAbilityKey then
            local abilityId = nil
            if State.activeAbilityKey == Enum.KeyCode.Two then
                abilityId = State.skill2AbilityId
            elseif State.activeAbilityKey == Enum.KeyCode.Three then
                abilityId = State.skill3AbilityId
            end
            
            if abilityId and ABILITY_CONFIG[abilityId] then
                local profile = ABILITY_CONFIG[abilityId]
                abilityFrame.Visible = true
                abilityFrame:FindFirstChild("IconFrame"):FindFirstChild("Icon").Image = abilityId
                abilityFrame:FindFirstChild("AbilityName").Text = profile.Name
                abilityFrame:FindFirstChild("AbilityStatus").Text = "Active"
            else
