-- ============================================================
-- PLAYER FOLDER MONITORING - ENHANCED WITH ALLY PERSISTENCE
-- ============================================================
local function setupPlayerFolderMonitoring()
    local playerFolder = getPlayerFolder()
    if not playerFolder then
        warn("⚠️ Player folder not found!")
        return
    end
    
    -- Initial scan with validation
    for _, child in ipairs(playerFolder:GetChildren()) do
        if isValidCharacterModel(child) then
            task.spawn(function()
                task.wait(0.3)
                monitorEnemyAnimations(child)
                if Config.ESP.Enabled then
                    setupESPForModel(child)
                end
                checkAndRecreateAllyMarker(child)
            end)
        end
    end
    
    -- Enhanced monitoring for new models with ally persistence
    State.playerFolderConnection = playerFolder.ChildAdded:Connect(function(child)
        task.wait(0.5)
        
        if isValidCharacterModel(child) then
            State.validModels[child] = true
            
            monitorEnemyAnimations(child)
            
            if Config.ESP.Enabled then
                setupESPForModel(child)
            end
            
            -- Check if this is a preset ally
            for _, presetName in ipairs(PRESET_ALLIES) do
                if child.Name == presetName then
                    task.wait(0.5)
                    createAllyMarker(child)
                    print("✅ Auto-marked preset ally: " .. presetName)
                    break
                end
            end
            
            checkAndRecreateAllyMarker(child)
            
            print("✅ Detected new model: " .. child.Name)
        end
    end)
    
    -- Enhanced cleanup on model removal
    playerFolder.ChildRemoved:Connect(function(child)
        State.validModels[child] = nil
        
        if State.deathConnections[child] then
            pcall(function() State.deathConnections[child]:Disconnect() end)
            State.deathConnections[child] = nil
        end
        
        State.monitoredModels[child] = nil
        
        removeAllyMarker(child, false) -- false = keep in tracking for respawn
        removeBlacklistMarker(child)
        
        removeESPForModel(child)
        
        if State.continuousAnimationMonitors[child] then
            for trackId, _ in pairs(State.continuousAnimationMonitors[child]) do
                stopContinuousMonitoring(child, trackId)
            end
            State.continuousAnimationMonitors[child] = nil
        end
        
        print("🗑️ Cleaned up model: " .. tostring(child.Name))
    end)
end

-- ============================================================
-- INPUT HANDLING - ENHANCED WITH MACRO SUPPORT AND GAMEPROCESSED
-- ============================================================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    -- Check if this input triggers a macro (with gameProcessed handling)
    if Config.Macros.Enabled then
        for _, macroConfig in ipairs(MACRO_CONFIG) do
            if macroConfig.enabled and input.KeyCode == macroConfig.triggerKey then
                local shouldIgnore = macroConfig.ignoreGameProcessed or false
                
                if gameProcessed and not shouldIgnore then
                    continue
                end
                
                local macroKey = "macro_" .. tostring(macroConfig.triggerKey)
                if debounceInput(macroKey, 0.3) then
                    executeMacro(macroConfig)
                    return
                end
            end
        end
    end
    
    -- Standard keybind handling (respect gameProcessed for normal inputs)
    if gameProcessed then return end
    
    if input.KeyCode == Config.Keybinds.ToggleAimLock then
        if debounceInput("aim_toggle_kb", 0.15) then
            Config.AimLock.Enabled = not Config.AimLock.Enabled
            State.aiming = Config.AimLock.Enabled
        end
    elseif input.KeyCode == Config.Keybinds.ManualTarget then
        if State.aiming and debounceInput("manual_target_kb", 0.1) then
            local target = getModelUnderMouse()
            if target and shouldTargetModel(target) then
                State.manualTarget = target
                State.currentTarget = target
            end
        end
    elseif input.KeyCode == Config.Keybinds.CycleMode then
        if debounceInput("mode_toggle_kb", 0.2) then
            local newMode = Config.AimLock.Mode + 1
            if newMode > #modeNames then newMode = 1 end
            Config.AimLock.Mode = newMode
        end
    elseif input.KeyCode == Config.Keybinds.Blacklist then
        if debounceInput("blacklist_toggle_kb", 0.3) then
            local target = getModelUnderMouse()
            if target then
                if isModelBlacklisted(target) then
                    removeFromBlacklist(target)
                else
                    addToBlacklist(target)
                end
            end
        end
    elseif input.KeyCode == Config.Keybinds.ToggleAlly then
        if debounceInput("ally_toggle_kb", 0.3) then
            local target = getModelUnderMouse()
            if target then toggleAllyMarker(target) end
        end
    elseif input.KeyCode == Config.Keybinds.ToggleTriggerbot then
        if debounceInput("triggerbot_toggle_kb", 0.2) then
            Config.Triggerbot.Enabled = not Config.Triggerbot.Enabled
        end
    elseif input.KeyCode == Config.Keybinds.ToggleESP then
        if debounceInput("esp_toggle_kb", 0.2) then
            toggleESP()
        end
    elseif input.KeyCode == Enum.KeyCode.Two or input.KeyCode == Enum.KeyCode.Three then
        State.lastAbilityKey = State.activeAbilityKey
        State.activeAbilityKey = input.KeyCode
        debugPrint("aim", "⚡ Ability activated: " .. (input.KeyCode == Enum.KeyCode.Two and "Skill 2" or "Skill 3"))
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Two or input.KeyCode == Enum.KeyCode.Three then
        if State.activeAbilityKey == input.KeyCode then
            State.lastAbilityKey = State.activeAbilityKey
            State.activeAbilityKey = nil
        end
    end
end)

-- ============================================================
-- MAIN RENDER LOOP - THE HEART OF THE SYSTEM
-- ============================================================
RunService.RenderStepped:Connect(function(dt)
    State.frameCounter = State.frameCounter + 1
    updateAbilityTracking()
    updateUnifiedHUD()
    updatePlayerHoverInfo()
    
    updateAllESP(dt)
    
    -- AIM LOCK LOGIC
    if Config.AimLock.Enabled and State.aiming then
        local myChar = LP.Character
        if not myChar then return end
        local myHum = getHum(myChar)
        local myRoot = myHRP()
        if not myHum or not myRoot then return end
        
        local now = tick()
        
        local upDot = myRoot.CFrame.UpVector.Y
        local notStanding = upDot < Config.Ragdoll.TiltThreshold
        if not State.ragdollActive and notStanding then
            State.ragdollActive = true
            State.ragdollExpireTime = now + Config.Ragdoll.DisableDuration
            myHum.AutoRotate = true
            updateTargetMarker(nil)
            return
        end
        
        if State.ragdollActive and now >= State.ragdollExpireTime then
            State.ragdollActive = false
        end
        
        if myHum.PlatformStand or State.ragdollActive then
            myHum.AutoRotate = true
            updateTargetMarker(nil)
            return
        end
        
        local target = selectTargetByMode()
        if not target or not isAlive(target) or not shouldTargetModel(target) then
            myHum.AutoRotate = true
            State.currentTarget = nil
            updateTargetMarker(nil)
            State.lastValidTarget = nil
            State.smoothedCameraRotation = nil
            State.lastAbilityKey = nil
            return
        end
        
        local targetHum = getHum(target)
        if targetHum and targetHum.Health <= 0 then
            myHum.AutoRotate = true
            State.currentTarget = nil
            updateTargetMarker(nil)
            State.lastValidTarget = nil
            State.smoothedCameraRotation = nil
            State.lastAbilityKey = nil
            return
        end
        
        State.currentTarget = target
        State.lastValidTarget = target
        updateTargetMarker(target)
        
        local targetRoot = getHRP(target)
        if not targetRoot or not Camera then return end
        
        local distance = (myRoot.Position - targetRoot.Position).Magnitude
        if distance > Config.AimLock.MaxDistance then
            myHum.AutoRotate = true
            State.currentTarget = nil
            updateTargetMarker(nil)
            State.lastValidTarget = nil
            State.smoothedCameraRotation = nil
            State.lastAbilityKey = nil
            return
        end
        
        local profile = getActiveAbilityProfile()
        local aimPos, lookahead, velocity = predictedPos(myRoot, targetRoot, distance, profile)
        
        local isLong = distance >= profile.LongRangeThreshold
        local smoothness = isLong and profile.Smoothness_Long or profile.Smoothness_Close
        
        myHum.AutoRotate = false
        
        local forceInstantSnap = Config.AimLock.InstantAbilitySnap and State.activeAbilityKey and State.lastAbilityKey ~= State.activeAbilityKey
        
        if Config.AimLock.ControlMode == 1 then
            rotateHRPToTarget(aimPos, smoothness, forceInstantSnap)
        elseif Config.AimLock.ControlMode == 2 then
            smoothCameraToTarget(aimPos, dt, forceInstantSnap)
        elseif Config.AimLock.ControlMode == 3 then
            rotateHRPToTarget(aimPos, smoothness, forceInstantSnap)
            smoothCameraToTarget(aimPos, dt, forceInstantSnap)
        end
        
        if forceInstantSnap then
            State.lastAbilityKey = State.activeAbilityKey
        end
    else
        local myChar = LP.Character
        if myChar then
            local hum = getHum(myChar)
            if hum then hum.AutoRotate = true end
        end
        updateTargetMarker(nil)
        State.lastAbilityKey = nil
    end
    
    -- DODGE SYSTEM LOGIC
    if Config.Dodge.Enabled then
        local hrp = myHRP()
        if hrp then
            local shouldDodge = false
            local dodgeKey = "Q"
            
            for obj, objData in pairs(State.trackedObjects) do
                if obj and obj.Parent then
                    local isThreat, keyToPress = checkQThreat(obj, objData)
                    if isThreat then
                        shouldDodge = true
                        dodgeKey = keyToPress or "Q"
                        break
                    end
                else
                    State.trackedObjects[obj] = nil
                    State.playerOwnedObjects[obj] = nil
                    State.includedQObjects[obj] = nil
                end
            end
            
            if shouldDodge then
                pressKey(dodgeKey)
            end
        end
    end
    
    -- TRIGGERBOT LOGIC
    if Config.Triggerbot.Enabled then
        if tick() - State.lastScanTime >= 0.05 then
            scanTriggerbotTargets()
            State.lastScanTime = tick()
        end
        checkAndAttackTriggerbot()
    end
end)

