-- TRIGGERBOT - Target Scanning & Attack Logic
-- ============================================================
local function scanTriggerbotTargets()
    local myRoot = myHRP()
    if not myRoot then return end
    local myPos = myRoot.Position
    local closestDist = math.huge
    local closestTarget = nil
    
    local allModels = getAllTargetModels()
    for _, characterModel in ipairs(allModels) do
        if shouldTargetModel(characterModel) then
            local root = characterModel:FindFirstChild("HumanoidRootPart")
            if root then
                local distance = (myPos - root.Position).Magnitude
                if distance <= Config.Triggerbot.DetectionRadius and distance < closestDist then
                    closestDist = distance
                    closestTarget = characterModel
                end
            end
        end
    end
    
    State.triggerbotTarget = closestTarget
end

local function checkAndAttackTriggerbot()
    if not Config.Triggerbot.Enabled or not State.triggerbotTarget then return end
    local myRoot = myHRP()
    if not myRoot then return end
    
    local targetRoot = State.triggerbotTarget:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not targetRoot.Parent then
        State.triggerbotTarget = nil
        return
    end
    
    local myPos = myRoot.Position
    local myVel = myRoot.AssemblyLinearVelocity
    local tPos = targetRoot.Position
    local tVel = targetRoot.AssemblyLinearVelocity
    
    local yDiff = math.abs(myPos.Y - tPos.Y)
    if yDiff > Config.Triggerbot.MaxYDifference then return end
    
    local dist = (myPos - tPos).Magnitude
    local toTarget = (tPos - myPos).Unit
    
    local horizT = getHorizontalVelocity(tVel)
    local tMag = horizT.Magnitude
    local tAlign = 0
    if tMag > Config.Triggerbot.MinRelMag then
        tAlign = (horizT / tMag):Dot(-toTarget)
    end
    
    local isHighSpeed = tMag > Config.Triggerbot.HighSpeedThreshold
    local effectiveRange = getEffectiveRange(myVel, tVel, toTarget, isHighSpeed)
    
    local tJumping = isJumping(tVel)
    local meJumping = isJumping(myVel)
    local upright = isStandingUpright(targetRoot)
    
    if tJumping and not meJumping and dist <= Config.Triggerbot.ImmediateJumpDistance and tick() - State.lastJumpTriggerTime > 0.5 then
        simulateJump()
    end
    
    if tJumping and not meJumping and dist > Config.Triggerbot.ImmediateJumpDistance and not State.interceptionData then
        State.interceptionData = calculateInterception(myPos, tPos, tVel, myVel)
    end
    
    if State.interceptionData and tick() >= State.interceptionData.jumpTime then
        simulateJump()
        State.interceptionData = nil
    end
    
    local shouldAttack = false
    local graceActive = (tick() - State.lastJumpTriggerTime) < Config.Triggerbot.JumpGracePeriod
    
    if not graceActive then
        if State.animationSchedules[State.triggerbotTarget] and tick() >= State.animationSchedules[State.triggerbotTarget] then
            shouldAttack = true
            State.animationSchedules[State.triggerbotTarget] = nil
            debugPrint("triggerbot", "[BLOCKED PUNISH M1]")
        elseif checkBlockedAnimation(State.triggerbotTarget) then
            State.animationSchedules[State.triggerbotTarget] = tick() + Config.Triggerbot.AttackDelayAfterAnimationStart
        end
    end
    
    local directionChangedToApproach = (State.previousTAlign < 0 and tAlign > 0) and dist <= effectiveRange
    
    if upright and not graceActive then
        local usePredicted = State.interceptionData
        local checkPos = tPos
        if usePredicted then
            checkPos = predictPosition(tPos, tVel, Config.Triggerbot.PredictionTime)
        end
        
        local rayOrigin = myPos + Vector3.new(0, 1.5, 0)
        local dir = (checkPos - rayOrigin).Unit
        RAYCAST_PARAMS.FilterDescendantsInstances = {LP.Character}
        local ray = Workspace:Raycast(rayOrigin, dir * (effectiveRange + Config.Triggerbot.RaycastBuffer), RAYCAST_PARAMS)
        
        if ray and ray.Instance:IsDescendantOf(State.triggerbotTarget) then
            local hitDist = (ray.Position - rayOrigin).Magnitude
            if hitDist <= effectiveRange and hitDist >= 2.5 and dist <= effectiveRange + 3 then
                shouldAttack = true
            end
        elseif dist <= effectiveRange then
            shouldAttack = true
        end
        
        if directionChangedToApproach then
            shouldAttack = true
        end
    end
    
    if shouldAttack then
        clickM1()
    end
    
    State.previousTAlign = tAlign
end

