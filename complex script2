-- ============================================================
-- VELOCITY TRACKING & PREDICTION
-- ============================================================
local VEL_EMA_ALPHA = 0.35
local function filteredVelocity(hrp)
    if not hrp or not hrp.Parent then return Vector3.zero end
    local raw = hrp.AssemblyLinearVelocity or hrp.Velocity or Vector3.zero
    local old = velEMA[hrp]
    if old then raw = old:Lerp(raw, VEL_EMA_ALPHA) end
    velEMA[hrp] = raw
    return raw
end

local function predictedPos(myRoot, targetRoot, distance, profile)
    if not myRoot or not targetRoot then return Vector3.zero, 0, Vector3.zero end
    
    local aimPos = targetRoot.Position
    local head = targetRoot.Parent and targetRoot.Parent:FindFirstChild("Head")
    if head then aimPos = head.Position end
    aimPos = aimPos + Vector3.new(0, profile.TargetOffset, 0)
    
    local isLong = distance >= profile.LongRangeThreshold
    local toVec = (aimPos - myRoot.Position)
    local dir = (toVec.Magnitude > 1e-6) and toVec.Unit or Vector3.new(0, 0, 1)
    
    local vel = filteredVelocity(targetRoot)
    local forwardVel = dir * vel:Dot(dir)
    local sidewaysVel = vel - forwardVel
    
    local BasePrediction = isLong and profile.BasePrediction_Long or profile.BasePrediction_Close
    local ScalingFactor = isLong and profile.ScalingFactor_Long or profile.ScalingFactor_Close
    local MaxPrediction = isLong and profile.MaxPrediction_Long or profile.MaxPrediction_Close
    local SidewaysWeight = isLong and profile.SidewaysWeight_Long or profile.SidewaysWeight_Close
    local MinDistance = isLong and profile.MinDistanceForPrediction_Long or profile.MinDistanceForPrediction_Close
    
    local adjustedVel = forwardVel + sidewaysVel * SidewaysWeight
    local lookahead = math.min(BasePrediction + (distance / ScalingFactor), MaxPrediction)
    if distance < MinDistance then lookahead = BasePrediction end
    lookahead = lookahead * curveFactor(distance)
    
    return aimPos + adjustedVel * lookahead, lookahead, vel
end

