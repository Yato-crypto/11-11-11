-- ============================================================
-- ZONE MARKER TRAJECTORY COLLISION
-- ============================================================
local function checkTrajectoryCollision(ownerHRP, targetHRP, config, isOwnerPlayer)
    if not Config.ESP.TrajectoryWarningEnabled or not config.trajectoryWarning then
        return false
    end
    
    if not ownerHRP or not targetHRP then return false end
    
    local myRoot = myHRP()
    if not myRoot then return false end
    
    local shouldWarn = false
    
    if config.type == "dome" then
        local centerPos = ownerHRP.Position
        local distanceFromCenter = (targetHRP.Position - centerPos).Magnitude
        local radius = config.distance
        
        local isInsideZone = distanceFromCenter <= radius
        
        local targetVel = filteredVelocity(targetHRP)
        local predictedPosition = targetHRP.Position + (targetVel * 0.5)
        local predictedDistance = (predictedPosition - centerPos).Magnitude
        local willCollide = predictedDistance <= radius
        
        shouldWarn = isInsideZone or willCollide
        
    elseif config.type == "spot" then
        local ownerLookVector = ownerHRP.CFrame.LookVector
        local spotCenter3D = ownerHRP.Position + (ownerLookVector * config.distance)
        
        local spotCenterXZ = Vector3.new(spotCenter3D.X, 0, spotCenter3D.Z)
        
        local baseSize = 3 * (config.size or 1)
        local spotRadius = baseSize / 2
        
        local targetPosXZ = Vector3.new(targetHRP.Position.X, 0, targetHRP.Position.Z)
        local distanceToSpot = (targetPosXZ - spotCenterXZ).Magnitude
        
        local isOnSpot = distanceToSpot <= spotRadius
        
        local targetVel = filteredVelocity(targetHRP)
        local predictedPosXZ = Vector3.new(
            targetHRP.Position.X + targetVel.X * 0.5,
            0,
            targetHRP.Position.Z + targetVel.Z * 0.5
        )
        local predictedDistToSpot = (predictedPosXZ - spotCenterXZ).Magnitude
        local willCollide = predictedDistToSpot <= spotRadius
        
        shouldWarn = isOnSpot or willCollide
        
    elseif config.type == "tile" then
        local direction = (targetHRP.Position - ownerHRP.Position).Unit
        local distance = (targetHRP.Position - ownerHRP.Position).Magnitude
        
        if distance <= config.distance then
            local midPoint = ownerHRP.Position + (direction * (distance / 2))
            midPoint = Vector3.new(midPoint.X, ownerHRP.Position.Y - 2.5, midPoint.Z)
            
            local targetPos2D = Vector3.new(targetHRP.Position.X, midPoint.Y, targetHRP.Position.Z)
            local distanceToPath = (targetPos2D - midPoint).Magnitude
            
            shouldWarn = distanceToPath <= 1
        end
    end
    
    return shouldWarn
end

-- ============================================================
-- SPOT MARKER
-- ============================================================
local function createSpotMarker(config, ownerHRP, targetHRP)
    local model = Instance.new("Model")
    model.Name = "ZoneMarker_Spot_" .. config.name
    
    local spot = Instance.new("Part")
    spot.Name = "Spot"
    
    local baseSize = 3 * (config.size or 1)
    
    if config.shapeType == "square" then
        spot.Shape = Enum.PartType.Block
        spot.Size = Vector3.new(baseSize, 0.1, baseSize)
    else
        spot.Shape = Enum.PartType.Cylinder
        spot.Size = Vector3.new(0.1, baseSize, baseSize)
    end
    
    spot.Color = config.color
    spot.Material = Enum.Material.Neon
    spot.CanCollide = false
    spot.Anchored = true
    spot.Transparency = config.transparency
    spot.Parent = model
    
    if config.imageId and config.imageId ~= "" then
        local decal = Instance.new("Decal")
        decal.Texture = config.imageId
        decal.Face = Enum.NormalId.Top
        decal.Transparency = config.transparency
        decal.Parent = spot
    end
    
    local lastUpdateTime = 0
    local cachedCFrame = CFrame.new()
    
    return model, function(dt, ownerModel, targetModel)
        local liveOwnerHRP = ownerModel and ownerModel:FindFirstChild("HumanoidRootPart")
        local liveTargetHRP = targetModel and targetModel:FindFirstChild("HumanoidRootPart")
        
        if not liveOwnerHRP or not liveOwnerHRP.Parent or not liveTargetHRP or not liveTargetHRP.Parent then return end
        
        local now = tick()
        if now - lastUpdateTime < 0.016 then return end
        lastUpdateTime = now
        
        local ownerLookVector = liveOwnerHRP.CFrame.LookVector
        local position = liveOwnerHRP.Position + (ownerLookVector * config.distance)
        position = Vector3.new(position.X, liveOwnerHRP.Position.Y - 2.5, position.Z)
        
        local newCFrame
        if config.shapeType == "square" then
            local lookAt = CFrame.new(position, position + ownerLookVector)
            newCFrame = lookAt
        else
            local lookAt = CFrame.new(position, position + ownerLookVector)
            newCFrame = lookAt * CFrame.Angles(0, 0, math.rad(90))
        end
        
        if cachedCFrame.Position ~= Vector3.new() then
            spot.CFrame = cachedCFrame:Lerp(newCFrame, 0.3)
        else
            spot.CFrame = newCFrame
        end
        cachedCFrame = spot.CFrame
        
        local isOwnerPlayer = config.applyTo == "player"
        local shouldWarn = checkTrajectoryCollision(liveOwnerHRP, liveTargetHRP, config, isOwnerPlayer)
        
        if shouldWarn then
            spot.Color = Config.ESP.TrajectoryWarningColor
        else
            spot.Color = config.color
        end
    end
end

-- ============================================================
-- TILE MARKER
-- ============================================================
local function createTileMarker(config, ownerHRP, targetHRP)
    local model = Instance.new("Model")
    model.Name = "ZoneMarker_Tile_" .. config.name
    
    local tile = Instance.new("Part")
    tile.Name = "Tile"
    tile.Size = Vector3.new(0.5, 0.1, 0.5)
    tile.Color = config.color
    tile.Material = Enum.Material.Neon
    tile.CanCollide = false
    tile.Anchored = true
    tile.Transparency = config.transparency
    tile.Parent = model
    
    if config.imageId and config.imageId ~= "" then
        local decal = Instance.new("Decal")
        decal.Texture = config.imageId
        decal.Face = Enum.NormalId.Top
        decal.Transparency = config.transparency
        decal.Parent = tile
    end
    
    local lastUpdateTime = 0
    local cachedCFrame = CFrame.new()
    local cachedColor = config.color
    
    return model, function(dt, ownerModel, targetModel)
        local liveOwnerHRP = ownerModel and ownerModel:FindFirstChild("HumanoidRootPart")
        local liveTargetHRP = targetModel and targetModel:FindFirstChild("HumanoidRootPart")
        
        if not liveOwnerHRP or not liveOwnerHRP.Parent or not liveTargetHRP or not liveTargetHRP.Parent then return end
        
        local now = tick()
        if now - lastUpdateTime < 0.016 then return end
        lastUpdateTime = now
        
        local direction = (liveTargetHRP.Position - liveOwnerHRP.Position).Unit
        local distance = (liveTargetHRP.Position - liveOwnerHRP.Position).Magnitude
        
        if distance <= config.distance then
            local midPoint = liveOwnerHRP.Position + (direction * (distance / 2))
            midPoint = Vector3.new(midPoint.X, liveOwnerHRP.Position.Y - 2.5, midPoint.Z)
            
            local newCFrame = CFrame.new(midPoint, Vector3.new(liveTargetHRP.Position.X, midPoint.Y, liveTargetHRP.Position.Z))
            
            if cachedCFrame.Position ~= Vector3.new() then
                tile.CFrame = cachedCFrame:Lerp(newCFrame, 0.3)
            else
                tile.CFrame = newCFrame
            end
            cachedCFrame = tile.CFrame
            
            tile.Size = Vector3.new(2, 0.1, distance)
            
            local isOwnerPlayer = config.applyTo == "player"
            local shouldWarn = checkTrajectoryCollision(liveOwnerHRP, liveTargetHRP, config, isOwnerPlayer)
            
            local targetColor = shouldWarn and Config.ESP.TrajectoryWarningColor or config.color
            
            if cachedColor ~= targetColor then
                tile.Color = cachedColor:Lerp(targetColor, 0.2)
                cachedColor = tile.Color
            end
        else
            tile.Size = Vector3.new(0.1, 0.1, 0.1)
            tile.CFrame = CFrame.new(0, -9999, 0)
        end
    end
end

