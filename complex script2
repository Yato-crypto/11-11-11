local function rotateHRPToTarget(aimPos, smoothness, forceInstant)
    local myRoot = myHRP()
    if not myRoot or not aimPos then return end
    
    local look = Vector3.new(aimPos.X, myRoot.Position.Y, aimPos.Z) - myRoot.Position
    if look.Magnitude < 0.01 then return end
    
    local desired = CFrame.new(myRoot.Position, myRoot.Position + look)
    
    if forceInstant or (Config.AimLock.InstantAbilitySnap and State.activeAbilityKey and State.lastAbilityKey ~= State.activeAbilityKey) then
        myRoot.CFrame = desired
        debugPrint("aim", "🎯 INSTANT SNAP to ability target!")
    else
        myRoot.CFrame = myRoot.CFrame:Lerp(desired, smoothness)
    end
end

local function smoothCameraToTarget(aimPos, dt, forceInstant)
    if not Camera or not aimPos then return end
    
    local currentCamCF = State.lastIntendedCameraRotation or Camera.CFrame
    local targetDirection = (aimPos - currentCamCF.Position).Unit
    local targetCamCF = CFrame.new(currentCamCF.Position, currentCamCF.Position + targetDirection)
    
    if forceInstant or (Config.AimLock.InstantAbilitySnap and State.activeAbilityKey and State.lastAbilityKey ~= State.activeAbilityKey) then
        Camera.CFrame = targetCamCF
        State.lastIntendedCameraRotation = targetCamCF
        debugPrint("aim", "🎯 INSTANT CAMERA SNAP to ability target!")
        return
    end
    
    local smoothFactor = Config.SmoothCamera.Smoothness
    
    if Config.SmoothCamera.AdaptiveSmoothing then
        local distance = (aimPos - currentCamCF.Position).Magnitude
        smoothFactor = smoothFactor * (1 + distance * 0.001)
    end
    
    local newCamCF = currentCamCF:Lerp(targetCamCF, smoothFactor)
    Camera.CFrame = newCamCF
    State.lastIntendedCameraRotation = newCamCF
end

