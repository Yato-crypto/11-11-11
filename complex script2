-- ============================================================
local function selectTargetByMode()
    local mode = Config.AimLock.Mode
    if mode == 1 then
        if State.manualTarget and isAlive(State.manualTarget) and shouldTargetModel(State.manualTarget) then
            return State.manualTarget
        end
        return nil
    end
    
    local myRoot = myHRP()
    if not myRoot then return nil end
    
    local allModels = getAllTargetModels()
    
    local candidates = {}
    
    for _, characterModel in ipairs(allModels) do
        if isAlive(characterModel) and shouldTargetModel(characterModel) then
            local targetRoot = getHRP(characterModel)
            if targetRoot then
                local distance = (myRoot.Position - targetRoot.Position).Magnitude
                if distance <= Config.AimLock.MaxDistance then
                    table.insert(candidates, {model = characterModel, distance = distance, root = targetRoot})
                end
            end
        end
    end
    
    if #candidates == 0 then return nil end
    
    if mode == 2 then
        table.sort(candidates, function(a, b) return a.distance < b.distance end)
        return candidates[1].model
    elseif mode == 3 then
        local closestBlacklisted, closestDist = nil, math.huge
        for _, data in ipairs(candidates) do
            if isModelBlacklisted(data.model) and data.distance < closestDist then
                closestBlacklisted = data.model
                closestDist = data.distance
            end
        end
        return closestBlacklisted
    elseif mode == 4 or mode == 5 then
        local bestCandidate = nil
        local bestHealth = mode == 4 and math.huge or 0
        
        for _, data in ipairs(candidates) do
            local hum = getHum(data.model)
            if hum then
                if (mode == 4 and hum.Health < bestHealth) or (mode == 5 and hum.Health > bestHealth) then
                    bestHealth = hum.Health
                    bestCandidate = data.model
                end
            end
        end
        return bestCandidate
    end
    
    return nil
end

