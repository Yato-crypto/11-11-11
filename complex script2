local function cleanupMemory()
    pcall(function()
        -- Clean velocity cache
        for hrp, _ in pairs(velEMA) do
            if not hrp or not hrp.Parent then velEMA[hrp] = nil end
        end
        
        -- Clean input buffer
        local now = tick()
        for inputKey, timestamp in pairs(State.inputBuffer) do
            if now - timestamp > 5 then State.inputBuffer[inputKey] = nil end
        end
        
        -- Clean blacklisted models
        for characterModel, _ in pairs(State.blacklistedModels) do
            if not characterModel or not characterModel.Parent then
                removeBlacklistMarker(characterModel)
                State.blacklistedModels[characterModel] = nil
            end
        end
        
        -- Clean ally marker references but keep name tracking
        for characterModel, modelName in pairs(State.alliedModelReferences) do
            if not characterModel or not characterModel.Parent then
                removeAllyMarker(characterModel, false) -- false = don't remove from tracking
                State.alliedModelReferences[characterModel] = nil
            end
        end
        
        -- Clean animation monitors
        for characterModel, monitors in pairs(State.continuousAnimationMonitors) do
            if not characterModel or not characterModel.Parent then
                for trackId, _ in pairs(monitors) do
                    stopContinuousMonitoring(characterModel, trackId)
                end
                State.continuousAnimationMonitors[characterModel] = nil
            end
        end
        
        -- Clean animation schedules
        for target, _ in pairs(State.animationSchedules) do
            if not target or not target.Parent then
                State.animationSchedules[target] = nil
            end
        end
        
        -- Refresh valid models regularly
        refreshValidModels()
    end)
end

