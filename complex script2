local function monitorEnemyAnimations(characterModel)
    if isMyCharacter(characterModel) or State.monitoredModels[characterModel] then return end
    State.monitoredModels[characterModel] = true
    
    local humanoid = characterModel:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then return end
    
    -- Enhanced death connection that preserves ally status
    local diedConn = humanoid.Died:Connect(function()
        removeESPOverlay(characterModel)
        removeESPHealthBar(characterModel)
        removeAllZoneMarkers(characterModel)
        
        if State.allyMarkers[characterModel] then
            removeAllyMarker(characterModel, false) -- false = keep in tracking for respawn
        end
        if State.blacklistMarkers[characterModel] then
            removeBlacklistMarker(characterModel)
        end
        
        State.monitoredModels[characterModel] = nil
    end)
    
    State.deathConnections[characterModel] = diedConn
    
    -- Monitor animation plays for dodge system
    animator.AnimationPlayed:Connect(function(track)
        if not Config.Dodge.AnimationDodgeEnabled or not Config.Dodge.Enabled then return end
        if isModelAllied(characterModel) then return end
        
        local animId = getAnimationId(track)
        if not animId then return end
        
        local animConfigs = ANIMATION_CONFIG[animId]
        if animConfigs then
            if type(animConfigs[1]) == "table" then
                for _, animData in ipairs(animConfigs) do
                    if animData.requiredItems then
                        if hasRequiredItems(animData.requiredItems, characterModel) then
                            local hrp = myHRP()
                            local enemyHRP = characterModel:FindFirstChild("HumanoidRootPart")
                            if hrp and enemyHRP then
                                local distance = (enemyHRP.Position - hrp.Position).Magnitude
                                
                                if animData.continuousCheck then
                                    startContinuousMonitoring(characterModel, track, animData, enemyHRP, distance)
                                else
                                    if distance <= animData.distance then
                                        local shouldCheckScope = animData.checkScope
                                        if Config.Dodge.DisableScopeChecks then
                                            shouldCheckScope = false
                                        elseif shouldCheckScope == nil then
                                            shouldCheckScope = Config.Dodge.AnimationCheckScope
                                        end
                                        
                                        if not shouldCheckScope or isInEnemyScope(enemyHRP, hrp.Position, animData.scope or 360) then
                                            -- v2.2: use smart parry
                                            executeSmartParry(animData, distance)
                                        end
                                    end
                                end
                            end
                            break
                        end
                    else
                        local hrp = myHRP()
                        local enemyHRP = characterModel:FindFirstChild("HumanoidRootPart")
                        if hrp and enemyHRP then
                            local distance = (enemyHRP.Position - hrp.Position).Magnitude
                            
                            if animData.continuousCheck then
                                startContinuousMonitoring(characterModel, track, animData, enemyHRP, distance)
                            else
                                if distance <= animData.distance then
                                    local shouldCheckScope = animData.checkScope
                                    if Config.Dodge.DisableScopeChecks then
                                        shouldCheckScope = false
                                    elseif shouldCheckScope == nil then
                                        shouldCheckScope = Config.Dodge.AnimationCheckScope
                                    end
                                    
                                    if not shouldCheckScope or isInEnemyScope(enemyHRP, hrp.Position, animData.scope or 360) then
                                        -- v2.2: use smart parry
                                        executeSmartParry(animData, distance)
                                    end
                                end
                            end
                        end
                        break
                    end
                end
            end
        end
    end)
end

