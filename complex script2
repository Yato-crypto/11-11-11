local function hasRequiredItems(requiredItems, characterModel)
    if not requiredItems or #requiredItems == 0 then return true end
    if not characterModel or not characterModel.Parent then return false end
    
    local playerFolder = Workspace:FindFirstChild("Player")
    if not playerFolder then return false end
    
    local modelFolder = playerFolder:FindFirstChild(characterModel.Name)
    if not modelFolder then return false end
    
    local itemModel = modelFolder:FindFirstChild("ItemModel")
    if not itemModel then return false end
    
    for _, itemName in ipairs(requiredItems) do
        if not itemModel:FindFirstChild(itemName) then
            return false
        end
    end
    
    return true
end

local function isInEnemyScope(enemyHRP, playerPos, scopeAngle)
    if not enemyHRP or not playerPos then return false end
    local enemyLookVector = enemyHRP.CFrame.LookVector
    local toPlayer = (playerPos - enemyHRP.Position).Unit
    local dotProduct = enemyLookVector:Dot(toPlayer)
    local angle = math.deg(math.acos(math.clamp(dotProduct, -1, 1)))
    return angle <= scopeAngle
end

local function getAnimationId(track)
    if track and track.Animation then return track.Animation.AnimationId end
    return nil
end

local function stopContinuousMonitoring(characterModel, trackId)
    if State.continuousAnimationMonitors[characterModel] and State.continuousAnimationMonitors[characterModel][trackId] then
        local monitorData = State.continuousAnimationMonitors[characterModel][trackId]
        if monitorData.connection then monitorData.connection:Disconnect() end
        State.continuousAnimationMonitors[characterModel][trackId] = nil
    end
end

local function startContinuousMonitoring(characterModel, track, animData, enemyHRP, distance)
    local trackId = tostring(track)
    
    if not State.continuousAnimationMonitors[characterModel] then
        State.continuousAnimationMonitors[characterModel] = {}
    end
    
    stopContinuousMonitoring(characterModel, trackId)
    
    local hasTriggeredDodge = false
    local monitorStartTime = tick()
    
    local connection = RunService.Heartbeat:Connect(function()
        if not track or not track.IsPlaying or not Config.Dodge.AnimationDodgeEnabled or not Config.Dodge.Enabled then
            stopContinuousMonitoring(characterModel, trackId)
            return
        end
        
        if not characterModel or not characterModel.Parent then
            stopContinuousMonitoring(characterModel, trackId)
            return
        end
        
        if isModelAllied(characterModel) or hasTriggeredDodge then return end
        
        local hrp = myHRP()
        local liveEnemyHRP = characterModel:FindFirstChild("HumanoidRootPart")
        if not hrp or not liveEnemyHRP or not liveEnemyHRP.Parent then
            stopContinuousMonitoring(characterModel, trackId)
            return
        end
        
        if animData.requiredItems and not hasRequiredItems(animData.requiredItems, characterModel) then
            stopContinuousMonitoring(characterModel, trackId)
            return
        end
        
        local currentDistance = (liveEnemyHRP.Position - hrp.Position).Magnitude
        if currentDistance > animData.distance then return end
        
        local currentLifetime = tick() - monitorStartTime
        if currentLifetime < (animData.minLifetime or 0.0) then return end
        
        -- Check scope (respects DisableScopeChecks override)
        local shouldCheckScope = animData.checkScope
        if Config.Dodge.DisableScopeChecks then
            shouldCheckScope = false
        elseif shouldCheckScope == nil then
            shouldCheckScope = Config.Dodge.AnimationCheckScope
        end
        
        local shouldDodge = false
        
        if shouldCheckScope then
            if isInEnemyScope(liveEnemyHRP, hrp.Position, animData.scope or 360) then
                shouldDodge = true
            end
        else
            shouldDodge = true
        end
        
        if shouldDodge then
            hasTriggeredDodge = true
            -- v2.2: use smart parry hierarchy instead of pressKey
            executeSmartParry(animData, currentDistance)
            stopContinuousMonitoring(characterModel, trackId)
        end
    end)
    
    State.continuousAnimationMonitors[characterModel][trackId] = {
        connection = connection,
        track = track,
        animData = animData,
        enemyHRP = enemyHRP,
        startTime = monitorStartTime
    }
    
    track.Stopped:Connect(function() stopContinuousMonitoring(characterModel, trackId) end)
end

