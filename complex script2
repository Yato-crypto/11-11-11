-- ============================================================
-- TRIGGERBOT SYSTEM
-- ============================================================
local RAYCAST_PARAMS = RaycastParams.new()
RAYCAST_PARAMS.FilterType = Enum.RaycastFilterType.Exclude
RAYCAST_PARAMS.IgnoreWater = true

local function predictPosition(pos, vel, time)
    return pos + vel * time - Vector3.new(0, 0.5 * Config.Triggerbot.Gravity * time * time, 0)
end

local function getHorizontalVelocity(vel)
    return Vector3.new(vel.X, 0, vel.Z)
end

local function isJumping(vel)
    return vel.Y > Config.Triggerbot.JumpVelocityThreshold
end

local function isStandingUpright(root)
    return root.CFrame.UpVector.Y >= Config.Triggerbot.MinUpvectorY
end

local function getEffectiveRange(myVel, tVel, toTargetDir, isHighSpeed)
    local horizMy = getHorizontalVelocity(myVel)
    local horizT = getHorizontalVelocity(tVel)
    local myMag = horizMy.Magnitude
    local tMag = horizT.Magnitude

    local maxRange = isHighSpeed and Config.Triggerbot.HighSpeedAttackRange or Config.Triggerbot.AttackRange

    if myMag <= Config.Triggerbot.MinRelMag and tMag <= Config.Triggerbot.MinRelMag then
        return maxRange
    end

    local myAlign = 0
    if myMag > Config.Triggerbot.MinRelMag then
        myAlign = (horizMy / myMag):Dot(toTargetDir)
    end

    local tAlign = 0
    if tMag > Config.Triggerbot.MinRelMag then
        tAlign = (horizT / tMag):Dot(-toTargetDir)
    end

    local myRetreat = math.max(-myAlign, 0)
    local myStrafe = 1 - math.abs(myAlign)

    local tRetreat = math.max(-tAlign, 0)
    local tStrafe = 1 - math.abs(tAlign)

    local avgRetreat = (myRetreat + tRetreat) / 2
    local avgStrafe = (myStrafe + tStrafe) / 2

    local strafeMax = isHighSpeed and Config.Triggerbot.StrafeReductionMaxHigh or Config.Triggerbot.StrafeReductionMaxNormal
    local retreatMax = isHighSpeed and Config.Triggerbot.RetreatReductionMaxHigh or Config.Triggerbot.RetreatReductionMaxNormal
    local chasingMax = isHighSpeed and Config.Triggerbot.ChasingReductionMaxHigh or Config.Triggerbot.ChasingReductionMaxNormal

    local reductionFraction = avgRetreat * retreatMax + avgStrafe * strafeMax

    local chasingFactor = math.max(myAlign, 0) * math.max(-tAlign, 0)
    reductionFraction = reductionFraction + chasingFactor * chasingMax

    local multiplier = 1 - reductionFraction

    if Config.Triggerbot.DebugPrints then
        print(string.format("My Align: %.2f, Target Align: %.2f, Avg Retreat: %.2f, Avg Strafe: %.2f, Chasing Factor: %.2f, Reduction: %.0f%%, Effective Range: %.2f",
            myAlign, tAlign, avgRetreat, avgStrafe, chasingFactor, reductionFraction * 100, maxRange * multiplier))
    end

    return maxRange * multiplier
end

local function simulateJump()
    if tick() - State.lastJumpTime < Config.Triggerbot.JumpDelay then return false end
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
    task.wait(0.04)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
    State.lastJumpTime = tick()
    State.lastJumpTriggerTime = tick()
    debugPrint("triggerbot", "[JUMP]")
    return true
end

local function calculateInterception(myPos, targetPos, targetVel, myVel)
    local bestDelay = nil
    local bestDist = math.huge

    for delay = 0, 0.35, 0.03 do
        for dt = 0, 0.8, 0.02 do
            local t = delay + dt
            local enemyFuture = predictPosition(targetPos, targetVel, t)
            local playerVel = Vector3.new(myVel.X, Config.Triggerbot.JumpPower, myVel.Z)
            local playerFuture = predictPosition(myPos, playerVel, t)
            local d = (playerFuture - enemyFuture).Magnitude
            if d < bestDist and d <= Config.Triggerbot.AttackRange + 6 then
                bestDist = d
                bestDelay = delay
            end
        end
    end

    if bestDelay then
        return {jumpTime = tick() + bestDelay, delayUsed = bestDelay}
    end
    return nil
end

local function checkBlockedAnimation(targetChar)
    local humanoid = targetChar:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end

    for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
        if track.Animation and track.Animation.AnimationId == Config.Triggerbot.BlockedAnimationID and track.IsPlaying then
            return true
        end
    end
    return false
end

local function clickM1()
    if tick() - State.lastClickTime < Config.Triggerbot.M1ClickDelay then return end
    VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
    VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
    State.lastClickTime = tick()
    debugPrint("triggerbot", "[M1]")
end

