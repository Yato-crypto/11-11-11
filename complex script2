-- ============================================================
-- ZONE MARKER ORCHESTRATION
-- ============================================================
createZoneMarker = function(config, characterModel)
    if not config.enabled then return end
    if not shouldShowESP(characterModel) then return end
    if not characterModel or not characterModel.Parent then return end
    
    local ownerModel, targetModel
    local ownerHRP, targetHRP
    
    if config.applyTo == "player" then
        ownerModel = LP.Character
        targetModel = characterModel
        ownerHRP = myHRP()
        targetHRP = getHRP(characterModel)
    else
        ownerModel = characterModel
        targetModel = LP.Character
        ownerHRP = getHRP(characterModel)
        targetHRP = myHRP()
    end
    
    if not ownerHRP or not targetHRP then return end
    
    local model, updateFunc
    
    if config.type == "spot" then
        model, updateFunc = createSpotMarker(config, ownerHRP, targetHRP)
    elseif config.type == "tile" then
        model, updateFunc = createTileMarker(config, ownerHRP, targetHRP)
    elseif config.type == "dome" then
        model, updateFunc = createDomeMarker(config, ownerHRP, targetHRP)
    end
    
    if model then
        model.Parent = workspace
        
        if not State.espZoneMarkers[characterModel] then
            State.espZoneMarkers[characterModel] = {}
        end
        
        State.espZoneMarkers[characterModel][config.name] = {
            model = model,
            updateFunc = updateFunc,
            config = config,
            ownerModel = ownerModel,
            targetModel = targetModel,
        }
    end
end

local function removeZoneMarker(characterModel, markerName)
    if State.espZoneMarkers[characterModel] and State.espZoneMarkers[characterModel][markerName] then
        pcall(function()
            State.espZoneMarkers[characterModel][markerName].model:Destroy()
        end)
        State.espZoneMarkers[characterModel][markerName] = nil
    end
end

removeAllZoneMarkers = function(characterModel)
    if State.espZoneMarkers[characterModel] then
        for markerName, _ in pairs(State.espZoneMarkers[characterModel]) do
            removeZoneMarker(characterModel, markerName)
        end
        State.espZoneMarkers[characterModel] = nil
    end
end

-- ============================================================
-- ZONE MARKER UPDATE LOOP
-- ============================================================
local function updateZoneMarkers(dt)
    if not Config.ESP.Enabled or not Config.ESP.ShowZoneMarkers then return end
    
    for characterModel, markers in pairs(State.espZoneMarkers) do
        if characterModel and characterModel.Parent then
            for markerName, markerData in pairs(markers) do
                if markerData.updateFunc then
                    pcall(function()
                        markerData.updateFunc(dt, markerData.ownerModel, markerData.targetModel)
                    end)
                end
            end
        else
            removeAllZoneMarkers(characterModel)
        end
    end
end

-- ============================================================
-- FULL ESP REFRESH FOR A MODEL
-- ============================================================
local function refreshESPForModel(characterModel)
    if not characterModel or isMyCharacter(characterModel) then return end
    
    removeESPOverlay(characterModel)
    removeESPHealthBar(characterModel)
    removeAllZoneMarkers(characterModel)
    
    if not Config.ESP.Enabled then return end
    if not characterModel.Parent then return end
    
    if Config.ESP.ShowOverlay then
        createESPOverlay(characterModel)
    end
    
    if Config.ESP.HealthBarEnabled then
        createESPHealthBar(characterModel)
    end
    
    if Config.ESP.ShowZoneMarkers then
        for _, markerConfig in ipairs(ESP_ZONE_MARKERS) do
            if markerConfig.enabled then
                createZoneMarker(markerConfig, characterModel)
            end
        end
    end
end

-- ============================================================
-- ESP SETUP / TEARDOWN / TOGGLE / MAIN UPDATE
-- ============================================================
local function setupESPForModel(characterModel)
    if not characterModel or isMyCharacter(characterModel) then return end
    
    State.espUpdateTimers[characterModel] = 0
    
    task.wait(0.5)
    
    refreshESPForModel(characterModel)
end

local function removeESPForModel(characterModel)
    removeESPOverlay(characterModel)
    removeESPHealthBar(characterModel)
    removeAllZoneMarkers(characterModel)
    State.espUpdateTimers[characterModel] = nil
end

local function toggleESP()
    Config.ESP.Enabled = not Config.ESP.Enabled
    
    if Config.ESP.Enabled then
        local allModels = getAllTargetModels()
        for _, characterModel in ipairs(allModels) do
            refreshESPForModel(characterModel)
        end
    else
        local allModels = getAllTargetModels()
        for _, characterModel in ipairs(allModels) do
            removeESPForModel(characterModel)
        end
    end
end

local function updateAllESP(dt)
    local now = tick()
    if now - State.lastESPUpdate < Config.ESP.UpdateRate then return end
    State.lastESPUpdate = now
    
    if not Config.ESP.Enabled then return end
    
    local allModels = getAllTargetModels()
    for _, characterModel in ipairs(allModels) do
        if characterModel.Parent then
            if Config.ESP.HealthBarEnabled then
                updateESPHealthBar(characterModel)
            end
            if Config.ESP.ShowOverlay then
                updateESPOverlay(characterModel)
            end
        end
    end
    
    if Config.ESP.ShowZoneMarkers then
        updateZoneMarkers(dt)
    end
end

