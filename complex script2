-- Enhanced ability detection with macro preference (FIXED)
local function canUseAbility(macroName)
    local abilityInfo = getAbilitySlotInfo()
    if not abilityInfo then return false, nil end
    
    -- Get macro preference (2 or 3)
    local macroData = MACRO_LIBRARY[macroName]
    local preferredSlot = macroData and macroData.preferredSlot or nil
    
    -- Check if each slot has a primary ability
    local skill2HasPrimary = false
    local skill3HasPrimary = false
    
    for _, primaryId in ipairs(FALLBACK_ABILITIES.primaryImageIds) do
        if abilityInfo.skill2ImageId == primaryId then
            skill2HasPrimary = true
        end
        if abilityInfo.skill3ImageId == primaryId then
            skill3HasPrimary = true
        end
    end
    
    -- If neither slot has a primary ability, return false
    if not skill2HasPrimary and not skill3HasPrimary then
        debugPrint("dodge", "❌ No primary abilities detected in any slot")
        return false, nil
    end
    
    -- Prioritize based on macro preference
    if preferredSlot == 2 then
        if skill2HasPrimary and abilityInfo.skill2Available then
            debugPrint("dodge", "🎯 Using preferred Skill2 (has primary ability + uses)")
            return true, Enum.KeyCode.Two
        elseif skill3HasPrimary and abilityInfo.skill3Available then
            debugPrint("dodge", "🔄 Falling back to Skill3 (Skill2 not available)")
            return true, Enum.KeyCode.Three
        end
    elseif preferredSlot == 3 then
        if skill3HasPrimary and abilityInfo.skill3Available then
            debugPrint("dodge", "🎯 Using preferred Skill3 (has primary ability + uses)")
            return true, Enum.KeyCode.Three
        elseif skill2HasPrimary and abilityInfo.skill2Available then
            debugPrint("dodge", "🔄 Falling back to Skill2 (Skill3 not available)")
            return true, Enum.KeyCode.Two
        end
    else
        -- No preference, check Skill2 first (default behavior)
        if skill2HasPrimary and abilityInfo.skill2Available then
            return true, Enum.KeyCode.Two
        elseif skill3HasPrimary and abilityInfo.skill3Available then
            return true, Enum.KeyCode.Three
        end
    end
    
    debugPrint("dodge", "❌ Primary abilities exist but have no uses")
    return false, nil
end

-- ============================================================
-- SMART PARRY SYSTEM v2.2 (Hierarchy + Auto-Detection)
-- ============================================================
local function executeSmartParry(animData, distance)
    if not animData.useDashCooldownCheck then
        -- Legacy behavior: just execute dash macro directly
        if animData.dashMacro then
            local delay = animData.parryDelay or 0
            if delay > 0 then
                task.delay(delay, function()
                    executeMacroByName(animData.dashMacro)
                end)
            else
                executeMacroByName(animData.dashMacro)
            end
        end
        return
    end
    
    -- New behavior: walk through the configured hierarchy
    local hierarchy = animData.hierarchy or {"dash", "ability", "block"}
    
    for _, option in ipairs(hierarchy) do
        if option == "dash" then
            if not isDashOnCooldown() then
                local delay = animData.parryDelay or 0
                debugPrint("dodge", "✅ Using DASH (hierarchy: " .. option .. ", delay: " .. delay .. "s)")
                if delay > 0 then
                    task.delay(delay, function()
                        executeMacroByName(animData.dashMacro)
                    end)
                else
                    executeMacroByName(animData.dashMacro)
                end
                return
            else
                debugPrint("dodge", "⏳ Dash on cooldown, trying next option...")
            end
            
        elseif option == "ability" then
            local canUse, detectedKey = canUseAbility(animData.abilityMacro)
            if canUse then
                local delay = animData.parryDelay or 0
                debugPrint("dodge", "✅ Using ABILITY " .. tostring(detectedKey) .. " (hierarchy: " .. option .. ", delay: " .. delay .. "s)")
                if delay > 0 then
                    task.delay(delay, function()
                        executeMacroByName(animData.abilityMacro, detectedKey)
                    end)
                else
                    executeMacroByName(animData.abilityMacro, detectedKey)
                end
                return
            else
                debugPrint("dodge", "❌ Ability not available, trying next option...")
            end
            
        elseif option == "block" then
            -- Block uses distance-based delays
            local delay = getBlockDelayForDistance(animData, distance)
            debugPrint("dodge", "✅ Using BLOCK (hierarchy: " .. option .. ", delay: " .. string.format("%.2f", delay) .. "s, distance: " .. string.format("%.1f", distance) .. ")")
            if delay > 0 then
                task.delay(delay, function()
                    executeMacroByName(animData.blockMacro)
                end)
            else
                executeMacroByName(animData.blockMacro)
            end
            return
        end
    end
    
    debugPrint("dodge", "❌ All parry options exhausted!")
end

