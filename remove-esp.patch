 local function getModelUnderMouse()
     local mouse = LP:GetMouse()
     if not mouse then return nil end
     local target = mouse.Target
     if not target then return nil end
     
     refreshValidModels()
     
     for model, _ in pairs(State.validModels) do
         if model and model.Parent and target:IsDescendantOf(model) then
             return model
         end
     end
     return nil
 end
 
